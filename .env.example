# Example environment for local Docker/Spring Boot startup.
# docker-compose.yml already contains these values explicitly,
# so this file is mainly a convenient reference.

POSTGRES_DB=student_test
POSTGRES_USER=student_test
POSTGRES_PASSWORD=student_test_password

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/student_test
SPRING_DATASOURCE_USERNAME=student_test
SPRING_DATASOURCE_PASSWORD=student_test_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_SQL_INIT_MODE=always
APP_DATA_LOADER_ENABLED=true
SERVER_PORT=8081
APP_STORAGE_LECTURE_MATERIALS_DIR=/app/uploads/lecture-materials
